# ──────────────────────────────────────────────
# Elemental Clash 게임노드 설정
# 이 파일을 .env로 복사하여 값을 입력하세요
# ──────────────────────────────────────────────

# [필수] 중앙서버 관리자에게 발급받은 API 키
NODE_API_KEY=

# [필수] 중앙서버 주소
CENTRAL_URL=http://central.example.com:7300

# [선택] 노드 고유 ID (미설정 시 자동 생성)
# NODE_ID=seoul-1

# [선택] 게임 서버 포트 (기본 7301)
# NODE_PORT=7301

# [선택] 리전 (매칭 시 참고)
# NODE_REGION=kr

# [선택] 최대 동시 방 수 (기본 20)
# NODE_MAX_ROOMS=20

# [선택] 연결 모드 강제 지정: upnp | relay | manual (기본 자동)
# NODE_MODE=

# [선택] 수동 모드일 때 외부 접속 주소 (포트포워딩 등)
# NODE_PUBLIC_URL=ws://my-server.com:7301

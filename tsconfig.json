{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "outDir": "./dist",
    "rootDir": "..",
    "sourceMap": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../packages/game-core/src/shared/*"],
      "@physics/*": ["../packages/game-core/src/physics/*"],
      "@engine/*": ["../packages/game-core/src/engine/*"]
    }
  },
  "include": ["src", "../packages/game-core/src"]
}
